// connect_page.slint — Receiver discovery and connection screen.
// Shown when AppState == Disconnected.
//
// SDK import path depth: ui/pages/ is 4 levels above the project root,
// so the SDK common.slint path gains one extra `../` vs. main.slint.
import { VerticalBox, Spinner, LineEdit } from "std-widgets.slint";
import { Bridge, Panel } from "../bridge.slint";
import { Theme } from "../theme.slint";
import { PrimaryButton } from "../components/buttons.slint";
import { ReceiverContextMenu } from "../components/receiver_context_menu.slint";
import { ConfirmDialog }       from "../components/confirm_dialog.slint";
export component ConnectView inherits Rectangle {
    // Context menu state.
    in-out property <bool>   show-context-menu: false;
    in-out property <string> context-receiver-id;
    in-out property <string> context-receiver-name;
    in-out property <length> context-menu-y: 0px;
    // Forget confirmation state.
    in-out property <bool> show-forget-confirm: false;
    VerticalBox {
        alignment: start;
        Text {
            horizontal-alignment: center;
            font-size: Theme.font-size-body;
            font-weight: 600;
            text: @tr("Connect to your receiver");
        }
        // ── Empty state: searching ────────────────────────────────────────
        if Bridge.devices.length == 0: Rectangle {
            height: 90px;
            border-radius: Theme.radius-card;
            background: Theme.surface-card;
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-default;
                Spinner {
                    indeterminate: true;
                    width: 24px;
                    height: 24px;
                }
                Text {
                    text: @tr("Searching for receivers…");
                    color: Theme.text-secondary;
                    vertical-alignment: center;
                }
            }
        }
        // ── Populated state: device list ──────────────────────────────────
        if Bridge.devices.length > 0: VerticalLayout {
            spacing: Theme.spacing-default;
            for device[idx] in Bridge.devices: Rectangle {
                height: Theme.row-height + 18px;
                property <bool> lp-armed: false;
                Timer {
                    interval: 600ms;
                    running: parent.lp-armed;
                    triggered => {
                        parent.lp-armed = false;
                        // Long press captures the stable receiver id for actions
                        // and the display name for the context menu title.
                        root.context-receiver-id = device.id;
                        root.context-receiver-name = device.name;
                        root.context-menu-y = (parent.height * idx) + 100px;
                        root.show-context-menu = true;
                    }
                }
                ta := TouchArea {
                    changed pressed => {
                        if self.pressed {
                            parent.lp-armed = true;
                        } else {
                            parent.lp-armed = false;
                        }
                    }
                    clicked => {
                        Bridge.connect-receiver(device.id);
                    }
                    Rectangle {
                        width: parent.width - 10px;
                        height: parent.height - 8px;
                        background: ta.pressed ? Theme.accent-pressed : Theme.surface-card;
                        border-radius: Theme.radius-card;
                        VerticalLayout {
                            padding-left: Theme.padding-screen;
                            padding-right: Theme.padding-screen;
                            alignment: center;
                            spacing: 2px;
                            Text {
                                text: device.name;
                                color: Theme.text-primary;
                                font-size: Theme.font-size-body;
                                overflow: elide;
                            }
                            Text {
                                text: device.address;
                                color: Theme.text-secondary;
                                font-size: Theme.font-size-label;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
        VerticalLayout {
            spacing: Theme.spacing-default;
            ip-input := LineEdit {
                placeholder-text: @tr("Receiver IP address");
                horizontal-stretch: 1;
            }
            PrimaryButton {
                width: parent.width;
                label: @tr("Connect");
                enabled: ip-input.text != "";
                // UI-only — no real connect handler in this phase.
                clicked => { /* placeholder */ }
            }
        }
        // "Pair via QR" button — between the receiver list and the bottom.
        HorizontalLayout {
            alignment: center;
            padding: 8px;
            Rectangle {
                width: 140px;
                height: 44px;
                border-radius: Theme.radius-card;
                background: Theme.surface-card;
                Text {
                    text: @tr("Pair via QR");
                    color: Theme.accent;
                    font-size: Theme.font-size-body;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea {
                    clicked => { Bridge.active-panel = Panel.pairing; }
                }
            }
        }
    }
    // Overlay layer: context menu scrim + menu.
    if root.show-context-menu: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000040;
        // Scrim tap dismisses.
        TouchArea {
            clicked => { root.show-context-menu = false; }
        }
        // Menu positioned near the long-pressed row.
        ReceiverContextMenu {
            x: (root.width - self.width) / 2;
            y: root.context-menu-y;
            show-disconnect: false;
            rename-clicked => {
                root.show-context-menu = false;
                Bridge.selected-receiver-id = root.context-receiver-id;
                Bridge.selected-receiver-name = root.context-receiver-name;
                Bridge.active-panel = Panel.receiver-rename;
            }
            set-default-clicked => {
                root.show-context-menu = false;
                // UI-only: no-op. Phase 8 wires to persistence.
            }
            forget-clicked => {
                root.show-context-menu = false;
                root.show-forget-confirm = true;
            }
            disconnect-clicked => {
                root.show-context-menu = false;
                // UI-only: no-op. Phase 8 wires to Bridge.disconnect-receiver(id).
            }
        }
    }
    // Forget confirmation dialog.
    if root.show-forget-confirm: ConfirmDialog {
        title: @tr("Forget receiver?");
        body: @tr("This receiver will be removed from your known devices list.");
        confirm-label: @tr("Forget");
        destructive: true;
        confirmed => {
            root.show-forget-confirm = false;
        }
        dismissed => {
            root.show-forget-confirm = false;
        }
    }
}
