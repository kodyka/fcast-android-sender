// bitrate_preset_edit_page.slint — Single-preset editor (UI-only).
//
// Reachable from BitratePresetsPage's "Add preset" button (and, in a
// future phase, from per-row edit affordances). Save and Cancel both
// just return to the list — no persistence in this phase.
//
// Slint docs ref:
//   draft/slint-ui/docs/astro/src/content/docs/reference/std-widgets/views/lineedit.mdx
//   draft/slint-ui/docs/astro/src/content/docs/reference/std-widgets/basic-widgets/slider.mdx

import { ScrollView, LineEdit } from "std-widgets.slint";
import { Bridge, Panel, BitratePreset } from "../bridge.slint";
import { PanelBridge } from "../state/panel_bridge.slint";
import { Theme } from "../theme.slint";
import { TextButton } from "../components/buttons.slint";
import {
    SettingsSection,
    SettingsSliderRow,
} from "../components/settings_rows.slint";

export component BitratePresetEditPage inherits Rectangle {
    // Source-of-truth for "are we editing an existing preset?" comes from
    // Bridge.selected-preset-id. The page maintains a draft locally so the
    // user can cancel without persisting partial edits.
    // Use `in-out property` so two-way bindings (<=>) do not permanently
    // override the declarative initialization logic. Instead, initialize
    // them manually.
    in-out property <string> draft-name;
    in-out property <float>  draft-kbps;

    init => {
        if (Bridge.selected-preset-id == "") {
            root.draft-name = "New preset";
            root.draft-kbps = 4000.0;
        } else {
            let p = preset-by-id(Bridge.presets, Bridge.selected-preset-id);
            root.draft-name = p.name;
            root.draft-kbps = p.bitrate-kbps;
        }
    }

    width: 100%;
    height: 100%;
    background: Theme.surface-primary;

    forward-focus: name-edit;
    panel-scope := FocusScope {
        key-pressed(event) => {
            if event.text == Key.Escape {
                PanelBridge.pop();
                return accept;
            }
            return reject;
        }

    VerticalLayout {
        // ── Header ──────────────────────────────────────────────────────
        Rectangle {
            height: 56px;
            background: Theme.surface-card;
            HorizontalLayout {
                padding: Theme.padding-screen;
                spacing: Theme.spacing-default;
                TextButton {
                    label: @tr("dismiss-dialog-button" => "Cancel");
                    // Return to the LIST, not the cast screen.
                    clicked => { PanelBridge.pop(); }
                }
                Text {
                    text: @tr("Edit preset");
                    color: Theme.text-primary;
                    font-size: Theme.font-size-heading;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    horizontal-stretch: 1;
                }
                TextButton {
                    label: @tr("save-button" => "Save");
                    clicked => {
                        Bridge.save-preset(
                            Bridge.selected-preset-id,
                            root.draft-name,
                            Math.round(root.draft-kbps),
                        );
                        PanelBridge.pop();
                    }
                }
            }
        }

        ScrollView {
            mouse-drag-pan-enabled: true;
            VerticalLayout {
                alignment: start;
                spacing: Theme.spacing-default;
                padding: Theme.padding-screen;

                SettingsSection {
                    title: @tr("NAME");
                    Rectangle {
                        height: 56px;
                        HorizontalLayout {
                            padding-left:  Theme.padding-screen;
                            padding-right: Theme.padding-screen;
                            name-edit := LineEdit {
                                placeholder-text: @tr("Preset name");
                                text <=> root.draft-name;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }

                SettingsSection {
                    title: @tr("BITRATE");
                    SettingsSliderRow {
                        title: @tr("Bitrate");
                        unit: " kbps";
                        minimum: 500;
                        maximum: 20000;
                        value <=> root.draft-kbps;
                        // Domain matches storage; `<=>` is safe.
                    }
                }
            }
        }
    }   // end VerticalLayout
    }   // end FocusScope

    // Helper since Slint has no built-in dictionary lookup. Slint 1.16
    // pure functions don't accept `for` loops in their body (only
    // repeaters do), so we hand-unroll a ternary chain — matching the
    // pattern used by `find-entry` in cast_history_detail_page.slint.
    //
    // CAP: 32 entries. If the user creates more than 32 presets, the
    // 33rd+ will silently appear as the empty fallback in the editor.
    // Phase 11 should move this lookup to Rust (push the resolved draft
    // fields into Bridge.draft-name / draft-kbps on selected-preset-id
    // change) to remove the cap entirely.
    pure function preset-by-id(list: [BitratePreset], id: string) -> BitratePreset {
        return list.length >  0 && list[ 0].id == id ? list[ 0] :
               list.length >  1 && list[ 1].id == id ? list[ 1] :
               list.length >  2 && list[ 2].id == id ? list[ 2] :
               list.length >  3 && list[ 3].id == id ? list[ 3] :
               list.length >  4 && list[ 4].id == id ? list[ 4] :
               list.length >  5 && list[ 5].id == id ? list[ 5] :
               list.length >  6 && list[ 6].id == id ? list[ 6] :
               list.length >  7 && list[ 7].id == id ? list[ 7] :
               list.length >  8 && list[ 8].id == id ? list[ 8] :
               list.length >  9 && list[ 9].id == id ? list[ 9] :
               list.length > 10 && list[10].id == id ? list[10] :
               list.length > 11 && list[11].id == id ? list[11] :
               list.length > 12 && list[12].id == id ? list[12] :
               list.length > 13 && list[13].id == id ? list[13] :
               list.length > 14 && list[14].id == id ? list[14] :
               list.length > 15 && list[15].id == id ? list[15] :
               list.length > 16 && list[16].id == id ? list[16] :
               list.length > 17 && list[17].id == id ? list[17] :
               list.length > 18 && list[18].id == id ? list[18] :
               list.length > 19 && list[19].id == id ? list[19] :
               list.length > 20 && list[20].id == id ? list[20] :
               list.length > 21 && list[21].id == id ? list[21] :
               list.length > 22 && list[22].id == id ? list[22] :
               list.length > 23 && list[23].id == id ? list[23] :
               list.length > 24 && list[24].id == id ? list[24] :
               list.length > 25 && list[25].id == id ? list[25] :
               list.length > 26 && list[26].id == id ? list[26] :
               list.length > 27 && list[27].id == id ? list[27] :
               list.length > 28 && list[28].id == id ? list[28] :
               list.length > 29 && list[29].id == id ? list[29] :
               list.length > 30 && list[30].id == id ? list[30] :
               list.length > 31 && list[31].id == id ? list[31] :
                                                       { id: "", name: "", bitrate-kbps: 0, active: false };
    }
}