import { Theme }    from "../theme.slint";
import { Bridge }   from "../bridge.slint";
import { LineEdit } from "std-widgets.slint";
import { PanelBridge } from "../state/panel_bridge.slint";

export component ReceiverRenamePage inherits Rectangle {
    width: 100%;
    height: 100%;
    background: Theme.surface-primary;

    in property <string> current-name;
    in-out property <string> draft-name: root.current-name;

    callback save(/* new-name */ string);
    callback cancel;

    forward-focus: name-edit;
    panel-scope := FocusScope {
        key-pressed(event) => {
            if event.text == Key.Escape {
                root.cancel();
                return accept;
            }
            return reject;
        }

    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.spacing-default;

        // Header.
        HorizontalLayout {
            alignment: space-between;

            Text {
                text: @tr("Rename receiver");
                color: Theme.text-primary;
                font-size: Theme.font-size-heading;
                vertical-alignment: center;
            }

            Rectangle {
                width: 60px;
                height: 36px;

                Text {
                    text: @tr("dismiss-dialog-button" => "Cancel");
                    color: Theme.accent;
                    font-size: Theme.font-size-body;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea {
                    clicked => { root.cancel(); }
                }
            }
        }

        // Name input.
        VerticalLayout {
            spacing: 8px;

            Text {
                text: @tr("Display name");
                color: Theme.text-secondary;
                font-size: Theme.font-size-label;
            }

            name-edit := LineEdit {
                text <=> root.draft-name;
                placeholder-text: @tr("Enter a name");
            }
        }

        // Spacer — push Save button towards bottom.
        Rectangle { vertical-stretch: 1; }

        // Save button.
        Rectangle {
            height: 48px;
            border-radius: Theme.radius-card;
            background: Theme.accent;

            Text {
                text: @tr("save-button" => "Save");
                color: Theme.text-primary;
                font-size: Theme.font-size-body;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            TouchArea {
                clicked => {
                    root.save(root.draft-name);
                }
            }
        }
    }   // end VerticalLayout
    }   // end FocusScope
}
