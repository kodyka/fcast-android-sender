// settings_page.slint — Pre-cast quality selection screen.
// Shown when AppState == SelectingSettings.
//
// Renamed from SelectingSettingsView → SettingsPageView to avoid collision
// with the full FullSettingsPage component added in Phase 7.
//
// MainWindow in main.slint references SettingsPageView.  The Rust side uses
// AppState::SelectingSettings (unchanged) — no Rust changes needed here.
//
// Shared settings widgets are vendored locally from the monorepo's mcore UI.

// Phase 7 adds FullSettingsPage in this same file.  It is a UI-only panel
// reachable from `PanelBridge.active == Panel.settings`.  All controls
// flip inline `in-out` properties on the page itself — no Rust round-trip.

import { VerticalBox, ScrollView } from "std-widgets.slint";
import { Utils, VideoResolutionPicker, FrameratePicker } from "../components/mcore/common.slint";
import { Bridge, Panel, LifecycleMode, MediaBackendKind } from "../bridge.slint";
import { PanelBridge } from "../state/panel_bridge.slint";
import { Theme } from "../theme.slint";
import { PrimaryButton, DestructiveButton, TextButton } from "../components/buttons.slint";
import {
    SettingsSection,
    SettingsValueRow,
    SettingsToggleRow,
} from "../components/settings_rows.slint";
import { PanelHeader } from "../components/panel_chrome.slint";

export component SettingsPageView inherits Rectangle {
    property <int> video-resolution-idx: 2;
    property <int> video-framerate-idx: 2;

    VerticalBox {
        Text {
            font-size: Theme.font-size-body;
            vertical-alignment: center;
            text: @tr("Max resolution");
        }

        VideoResolutionPicker {
            current-index <=> video-resolution-idx;
        }

        Text {
            font-size: Theme.font-size-body;
            vertical-alignment: center;
            text: @tr("Max framerate");
        }

        FrameratePicker {
            current-index <=> video-framerate-idx;
        }

        PrimaryButton {
            label: @tr("start-cast-button" => "Start");
            clicked => {
                let scale = Utils.str-to-scale(video-resolution-idx);
                Bridge.start-casting(scale.width, scale.height, Utils.video-framerates[video-framerate-idx].to-float())
            }
        }

        DestructiveButton {
            label: @tr("Disconnect");
            clicked => { Bridge.stop-casting(); }
        }
    }
}

export component FullSettingsPage inherits Rectangle {
    // ── UI-only stub state ───────────────────────────────────────────────
    // All flips live on this component. Phase 8 swaps these for Bridge
    // setters + Rust-backed handlers.
    in-out property <int>    resolution-idx: 2;
    in-out property <int>    framerate-idx:  2;
    in-out property <bool>   mdns-enabled:   true;

    // Fill the parent (overlay layer in main.slint passes parent.width/height).
    width: 100%;
    height: 100%;
    background: Theme.surface-primary;

    VerticalLayout {
        // ── Header ────────────────────────────────────────────────────────
        PanelHeader {
            title: @tr("Settings");
            close-clicked => { PanelBridge.pop(); }
        }

        // ── Body (scrollable) ─────────────────────────────────────────────
        ScrollView {
            mouse-drag-pan-enabled: true;
            VerticalLayout {
                alignment: start;
                spacing: Theme.spacing-default;
                padding: Theme.padding-screen;

                // ── Section: PRIVACY ──────────────────────────────────────
                SettingsSection {
                    title: @tr("PRIVACY");
                    SettingsValueRow {
                        title: @tr("Lock UI");
                        value: @tr("Enter");
                        clicked => { Bridge.engage-lock(); }
                    }
                    SettingsValueRow {
                        title: @tr("Stealth mode");
                        value: @tr("Enter");
                        clicked => { Bridge.engage-stealth(); }
                    }
                    SettingsValueRow {
                        title: @tr("Cast with countdown");
                        value: @tr("{}s", Bridge.snapshot-secs);
                        clicked => {
                            Bridge.start-snapshot-countdown(Bridge.snapshot-secs);
                        }
                    }
                }

                // ── Section: RECEIVER ─────────────────────────────────────
                SettingsSection {
                    title: @tr("RECEIVER");
                    SettingsValueRow {
                        title: @tr("Discovered receivers");
                        value: @tr("{n} receiver found" | "{n} receivers found" % Bridge.devices.length);
                        // UI-only — would open the connect page.
                        clicked => { /* placeholder */ }
                    }
                    SettingsToggleRow {
                        title: @tr("mDNS discovery");
                        checked: root.mdns-enabled;
                        toggled(checked) => { root.mdns-enabled = checked; }
                    }
                }

                // ── Section: AUDIO & VIDEO ────────────────────────────────
                // Cycle-on-click is a placeholder UX. Real picker panels
                // land in `futures/`.
                SettingsSection {
                    title: @tr("AUDIO & VIDEO");
                    SettingsValueRow {
                        title: @tr("Audio");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.audio); }
                    }
                    SettingsValueRow {
                        title: @tr("Bitrate");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.bitrate-presets); }
                    }
                    SettingsValueRow {
                        title: @tr("Camera");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.camera); }
                    }
                    SettingsValueRow {
                        title: @tr("Max resolution");
                        value: ["480p", "720p", "1080p", "1440p"][Math.clamp(root.resolution-idx, 0, 3)];
                        clicked => {
                            root.resolution-idx = Math.mod(root.resolution-idx + 1, 4);
                        }
                    }
                    SettingsValueRow {
                        title: @tr("Max framerate");
                        value: ["24 fps", "30 fps", "60 fps"][Math.clamp(root.framerate-idx, 0, 2)];
                        clicked => {
                            root.framerate-idx = Math.mod(root.framerate-idx + 1, 3);
                        }
                    }
                }

                // ── Section: DISPLAY ──────────────────────────────────────
                SettingsSection {
                    title: @tr("DISPLAY");
                    SettingsValueRow {
                        title: @tr("Quick actions");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.quick-actions); }
                    }
                }

                // ── Section: CODEC & DEBUG ────────────────────────────────
                SettingsSection {
                    title: @tr("CODEC & DEBUG");
                    SettingsValueRow {
                        title: @tr("H.264 encoder test");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.codec-test); }
                    }
                    SettingsValueRow {
                        title: @tr("Debug log");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.debug-log); }
                    }
                    SettingsValueRow {
                        title: @tr("Video pipeline");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.debug-video); }
                    }
                    SettingsValueRow {
                        title: @tr("Media backend");
                        value: Bridge.media-backend == MediaBackendKind.migration
                            ? @tr("Migration (in-process)")
                            : @tr("gst-pop ({})", Bridge.gstpop-url);
                        clicked => { PanelBridge.push(Panel.media-backend); }
                    }
                    SettingsValueRow {
                        title: @tr("Service configuration");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.service-config); }
                    }
                    SettingsValueRow {
                        title: @tr("SRT sources & overlays");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.srt-config); }
                    }
                }

                // ── Section: DATA ─────────────────────────────────────────
                SettingsSection {
                    title: @tr("DATA");
                    SettingsValueRow {
                        title: @tr("Backup & reset");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.backup-reset); }
                    }
                    SettingsValueRow {
                        title: @tr("Cast history");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.cast-history); }
                    }
                }

                // ── Section: ADVANCED ─────────────────────────────────────
                SettingsSection {
                    title: @tr("ADVANCED");
                    SettingsValueRow {
                        title: @tr("Recording");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.recording); }
                    }
                    SettingsValueRow {
                        title: @tr("Network");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.network); }
                    }
                    SettingsValueRow {
                        title: @tr("Mixer");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.mixer); }
                    }
                }

                // ── Section: AUTOMATION ───────────────────────────────────
                SettingsSection {
                    title: @tr("AUTOMATION");
                    SettingsValueRow {
                        title: @tr("Macros");
                        value: @tr("open-panel-action" => "Open");
                        clicked => { PanelBridge.push(Panel.macros); }
                    }
                }

                // ── Section: ABOUT ────────────────────────────────────────
                SettingsSection {
                    title: @tr("ABOUT");
                    SettingsValueRow {
                        title: @tr("App version");
                        value: Bridge.app-version;
                        show-chevron: false;
                    }
                    SettingsValueRow {
                        title: @tr("FCast protocol");
                        value: "v3";
                        show-chevron: false;
                    }
                }
            }
        }
    }
}
