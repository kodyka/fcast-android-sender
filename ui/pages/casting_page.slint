// casting_page.slint — Waiting-for-media and active-casting screens.
// Both views share this file as they represent adjacent cast lifecycle states.
//
//   WaitingForMediaView  →  AppState == WaitingForMedia
//   CastingView          →  AppState == Casting
//
// Phase 5 will add StatusOverlay as a ZStack layer on top of CastingView.
// Phase 4 will refine the CastButton state machine here.

import { VerticalBox } from "std-widgets.slint";
import { Bridge, AppState } from "../bridge.slint";
import { StatusItem, StatusSeverity } from "../bridge.slint";
import { LoadingView, DestructiveButton } from "../components/buttons.slint";
import { StatusOverlay } from "../components/status_overlay.slint";

export component CastButton inherits Rectangle {
    // This component dynamically switches label and style based on AppState.
    // It should only be visible/instantiated in WaitingForMedia and Casting states.

    if Bridge.app-state == AppState.WaitingForMedia: DestructiveButton {
        label: @tr("cancel-cast-button" => "Cancel");
        clicked => { Bridge.stop-casting(); }
    }

    if Bridge.app-state == AppState.Casting: DestructiveButton {
        label: @tr("Stop Casting");
        clicked => { Bridge.stop-casting(); }
    }
}

// ── WaitingForMediaView ───────────────────────────────────────────────────────

export component WaitingForMediaView inherits Rectangle {
    VerticalBox {
        alignment: center;
        LoadingView {
            label: @tr("Waiting for media");
        }

        CastButton {}
    }
}

// ── CastingView ───────────────────────────────────────────────────────────────

export component CastingView inherits Rectangle {
    VerticalBox {
        alignment: center;
        Text {
            horizontal-alignment: center;
            text: @tr("Casting");
        }

        CastButton {}
    }

    StatusOverlay {
        x: 0;
        y: 0;
        width: parent.width * 0.5;
        items: Bridge.status-items;
    }
}
