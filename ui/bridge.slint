// bridge.slint — AppState enum and Bridge global singleton.
// Single source of truth for all properties and callbacks shared between
// Slint UI and Rust backend.
//
// Re-exported from main.slint so that slint_build::compile("ui/main.slint")
// exposes Bridge and AppState to Rust via ui.global::<Bridge>().
//
// Slint docs ref (globals): draft/slint/docs/astro/src/content/docs/guide/language/coding/globals.mdx
// Slint docs ref (enums):   draft/slint/docs/astro/src/content/docs/guide/language/coding/structs-and-enums.mdx

export enum LifecycleMode {
    normal,
    lock-screen,
    stealth,
    snapshot-countdown,
}

// New in Phase 8 / Cluster F. Drives both Bridge.banner-* and any page-
// local banner that wants to consume the same semantics.
export enum BannerSeverity {
    info,
    success,
    warning,
    error,
}

export enum RecordingState {
    idle,
    recording,
    paused,
    finalizing,
}

export enum MixerState {
    idle,
    starting,
    running,
    stopping,
    error,
}

export enum AppState {
    Disconnected,
    Connecting,
    SelectingSettings,
    WaitingForMedia,
    Casting,
}

export enum MediaBackendKind {
    migration,
    gst-pop,
}

export enum MediaBackendState {
    disconnected,
    probing,
    ready,
    error,
}

export struct MacroStep {
    action-id: string,    // matches QuickAction.id
    label:     string,    // display label
}

export struct Macro {
    id:       string,
    name:     string,
    steps:    [MacroStep],
    enabled:  bool,
}

export enum LogLevel {

    trace,
    debug,
    info,
    warning,
    error,
}

export struct LogEntry {
    level:     LogLevel,
    timestamp: string,
    target:    string,
    message:   string,
}

export enum Panel {
    none,
    settings,
    debug,
    codec-test,
    backup-reset,
    audio,
    camera,
    quick-actions,
    cast-history,
    cast-history-detail,
    recording,
    pairing,
    receiver-rename,
    bitrate-presets,
    bitrate-preset-edit,
    macros,
    macro-edit,
    debug-log,
    debug-video,
    network,
    mixer,
    media-backend,
}

export struct QuickAction {
    id:      string,
    title:   string,
    enabled: bool,
    active:  bool,
    is-macro: bool,
}

export enum StatusSeverity { info, warning, error }

export struct StatusItem {
    label:    string,
    value:    string,
    severity: StatusSeverity,
    icon-glyph: string,
}

export struct ReceiverItem {
    id:      string,
    name:    string,
    address: string,
    ip:      string,
    port:    int,
    kind:    string,
    is-default: bool,
}

export struct BitratePreset {
    id:           string,
    name:         string,
    bitrate-kbps: int,
    active:       bool,
}

export struct CastHistoryEntry {
    id:         string,
    receiver:   string,
    started-at: string,
    duration-s: int,
    status:     string,
}

export struct NetworkInterface {
    name:        string,
    kind:        string,    // "wifi" / "ethernet" / "cellular" / "loopback"
    address-v4:  string,
    address-v6:  string,
    enabled:     bool,
}

export struct SrtSource {
    slot-id:    string,
    enabled:    bool,
    uri:        string,
    latency-ms: int,
    stream-id:  string,
    mix-alpha:  float,
    mix-zorder: int,
    mix-volume: float,
    state:      MixerState,
    last-error: string,
}

export struct RtmpDestination {
    node-id:    string,
    enabled:    bool,
    uri:        string,
    stream-key: string,
    state:      MixerState,
    last-error: string,
}

export struct MixerCanvas {
    node-id:     string,
    width:       int,
    height:      int,
    sample-rate: int,
    state:       MixerState,
    last-error:  string,
}

export global Bridge {
    // ── Data properties (Rust → Slint) ──────────────────────────────────
    in property <[ReceiverItem]> devices: [
        // { id: "Device 1", name: "Device 1", address: "...", ip: "...",
        //   port: 46899, kind: "fcast", is-default: false },
    ];
    // ── Status overlay (Phase 8 / Cluster A1) ───────────────────────────
    in property <[StatusItem]> status-items: [];
    // ── Build / version (Phase 8 / Cluster A2) ──────────────────────────
    in property <string> app-version: "";
    // ── Network interfaces (Phase 8 / Cluster A3) ───────────────────────
    in property <[NetworkInterface]> network-interfaces: [];
    callback set-interface-enabled(string, bool);
    callback back-requested();
    // ── Recording (Phase 8 / Cluster A4) ────────────────────────────────
    in property <RecordingState> recording-state:    RecordingState.idle;
    in property <int>            recording-elapsed-s: 0;
    // ── Debug log (Phase 8 / Cluster A5) ────────────────────────────────
    in property <[LogEntry]> log-entries: [];
    callback clear-log-entries();
    in-out property <AppState> app-state: AppState.Disconnected;
    in-out property <Panel>    active-panel: Panel.none;
    // ── Banner (Phase 8 / Cluster F1) ───────────────────────────────────
    // Rust pushes a banner with severity; auto-hide is handled by
    // Rust's `flash_banner` helper (consumer is `components/info_banner.slint`).
    in-out property <string>          banner-message:  "";
    in-out property <bool>            banner-visible:  false;
    in-out property <BannerSeverity>  banner-severity: BannerSeverity.info;

    // ── Macros (Phase 8 / Cluster C4) ───────────────────────────────────
    in property <[Macro]> macros: [];
    callback save-macro(string, string, [MacroStep], bool);   // (id, name, steps, enabled); id="" → new
    callback delete-macro(string);                            // (id)
    callback run-macro(string);                               // (macro-id)

    in-out property <string>  macro-edit-id: "";   // "" means "new macro"
    in-out property <string>  draft-macro-name: "";
    in-out property <bool>    draft-macro-enabled: true;
    in property <[MacroStep]> draft-macro-steps: [];
    callback load-draft-macro(string);                        // (macro-id)
    callback draft-add-step(string);                          // (action-id)
    callback draft-remove-step(int);                          // (step-idx)
    callback draft-move-step(int, int);                       // (from-idx, to-idx)

    in-out property <LifecycleMode> lifecycle: LifecycleMode.normal;
    in-out property <int> snapshot-secs: 5;
    in-out property <int> audio-source-idx: 0;
    in-out property <bool> audio-muted: false;
    in-out property <float> audio-input-gain: 0.7;
    in-out property <int> audio-bitrate-idx: 1;
    in-out property <int> camera-idx: 1;
    in-out property <int> resolution-idx: 2;
    in-out property <int> framerate-idx: 1;
    in-out property <bool> camera-mirror-front: true;
    in-out property <bool> camera-stabilization: true;
    in-out property <bool> camera-tap-to-focus: true;
    in-out property <float> camera-zoom-level: 1.0;
    in-out property <bool> wifi-aware-enabled: false;
    in-out property <string>   selected-history-id: "";
    in-out property <bool>     show-debug: false;
    in-out property <string>   test-status: "";
    in property <[QuickAction]> quick-actions: [];
    callback move-bar-action(int, int);
    callback set-bar-action-enabled(int, bool);
    callback save-bar-actions();
    in-out property <string> selected-receiver-id;
    in-out property <string> selected-receiver-name;

    // ── Backup / reset (Phase 8 / Cluster D1) ───────────────────────────
    callback export-settings();
    callback import-settings();
    callback reset-settings();
    callback clear-cast-history();
    callback clear-known-receivers();

    // ── Cast history (Phase 8 / Cluster D2) ─────────────────────────────
    in property <[CastHistoryEntry]> history: [];
    in property <CastHistoryEntry> selected-history-entry;
    callback selected-history-id-changed(string);
    changed selected-history-id => {
        Bridge.selected-history-id-changed(Bridge.selected-history-id);
    }
    callback clear-history();
    callback delete-history-entry(string);
    callback recast(string);                          // (entry-id)

    // ── Bitrate presets (Phase 8 / Cluster C1) ──────────────────────────
    in property <[BitratePreset]> presets: [];
    in-out property <string>      selected-preset-id: "";   // for the edit-page route-back
    callback save-preset(string, string, int);              // (id, name, kbps); id="" → new
    callback delete-preset(string);                         // (id)
    callback set-active-preset(string);                     // (id)

    // ── Media backend selector (MVP-PHASE-12) ───────────────────────────
    in-out property <MediaBackendKind> media-backend: MediaBackendKind.migration;
    in property <MediaBackendState> media-backend-state: MediaBackendState.disconnected;
    in property <string> media-backend-status-text: "";
    in property <string> media-backend-error-text: "";
    in-out property <string> gstpop-url: "ws://127.0.0.1:9000";
    in-out property <string> gstpop-api-key: "";
    in-out property <string> gstpop-pipeline-id: "0";

    // ── Callbacks (Slint → Rust) ─────────────────────────────────────────
    callback connect-receiver(string);
    callback start-casting(scale-width: int, scale-height: int, max-framerate: int);
    callback stop-casting();
    callback invoke-action(string);
    callback start-recording();
    callback pause-recording();
    callback resume-recording();
    callback stop-recording();
    callback engage-lock();
    callback engage-stealth();
    callback start-snapshot-countdown(int);
    callback exit-lifecycle();
    callback set-wifi-aware(bool);

    // ── Migration-runtime callbacks (MVP-PHASE-9) ───────────────────────
    callback start-migration-server(string); // (bind-addr)
    callback run-migration-test(string); // (test-id: "getinfo" | "crossfade" | "smoke")
    callback stop-migration-server();

    // ── Media backend selector callbacks (MVP-PHASE-12) ────────────────
    callback save-media-backend-settings();
    callback probe-media-backend();
    callback apply-media-backend();

    // ── Mixer screen (MVP-PHASE-11) ──────────────────────────────────────
    in-out property <SrtSource> srt-source-a: {
        slot-id:    "",
        enabled:    true,
        uri:        "",
        latency-ms: 2000,
        stream-id:  "",
        mix-alpha:  1.0,
        mix-zorder: 0,
        mix-volume: 1.0,
        state:      MixerState.idle,
        last-error: "",
    };
    in-out property <SrtSource> srt-source-b: {
        slot-id:    "",
        enabled:    true,
        uri:        "",
        latency-ms: 2000,
        stream-id:  "",
        mix-alpha:  1.0,
        mix-zorder: 1,
        mix-volume: 1.0,
        state:      MixerState.idle,
        last-error: "",
    };
    in-out property <RtmpDestination> rtmp-destination: {
        node-id:    "",
        enabled:    true,
        uri:        "",
        stream-key: "",
        state:      MixerState.idle,
        last-error: "",
    };
    in-out property <MixerCanvas> mixer-canvas: {
        node-id:     "",
        width:       1280,
        height:      720,
        sample-rate: 44100,
        state:       MixerState.idle,
        last-error:  "",
    };
    in property <MixerState> mixer-state: MixerState.idle;
    in property <string> mixer-error-text: "";

    callback start-mixer-cast();
    callback stop-mixer-cast();
    // (slot-id, alpha, z-order, volume)
    callback apply-mixer-slot-config(string, float, int, float);
    // (width-px, height-px, sample-rate-hz)
    callback apply-mixer-canvas(int, int, int);

    // ── Public functions (callable from Slint) ───────────────────────────
    public function change-state(to: AppState) {
        Bridge.app-state = to;
    }
}
