// main.slint — Thin root file compiled by slint_build::compile("ui/main.slint").
//
// =====================================================================
// Bridge invariants (Phase 8 / Cluster E)
// =====================================================================
//
// 1. PanelBridge.active — managed by PanelBridge.push/pop/replace/close-all.
//    No direct property writes anywhere in Slint or Rust.
//
// 2. Bridge.lifecycle — Rust is the authoritative writer (set_lifecycle).
//    Slint exit paths call Bridge.exit-lifecycle(); no direct property writes.
//    Settings rows that *engage* a lifecycle mode go through
//    Bridge.engage-lock / engage-stealth / start-snapshot-countdown callbacks.
//
// 3. Bridge.app-state — Slint writes ONLY via Bridge.change-state(to).
//    No Slint-side direct writes (`Bridge.app-state = ...`). Rust writes
//    only via invoke_change_state, which calls change-state internally.
//
// Breaking any of these invariants will produce subtle bugs that race
// with the UI thread. Treat changes to these properties' producers /
// consumers as cross-cutting and review them as a unit.
// =====================================================================
//
// Responsibilities:
//   1. Import Bridge and AppState from bridge.slint for use by MainWindow,
//      and re-export them so slint_build generates the Rust bindings and
//      ui.global::<Bridge>() resolves at runtime.
//   2. Import all page components.
//   3. Declare MainWindow and route AppState to the correct page.
//
// Per Slint module docs, `export { X } from "..."` is *re-export only* — it
// publishes the symbol but does not bring it into the current file's scope.
// Two separate statements are required when a symbol is both used locally and
// re-exported (the canonical pattern shown in the Slint Modules reference):
//   import { X } from "other.slint";
//   export { X }
// Note: `import` ends with `;`, but a bare `export { ... }` block has no
// trailing semicolon — the slint v1.15.1 parser rejects it as "extra
// semicolon" if you add one.
// Reference: https://releases.slint.dev/1.15.1/docs/slint/src/language/syntax/modules
//
// All UI logic lives in the imported modules:
//   bridge.slint          — AppState enum + Bridge global
//   theme.slint           — design tokens (stub, populated Phase 2)
//   pages/connect_page    — ConnectView
//   pages/connecting_page — ConnectingView
//   pages/settings_page   — SettingsPageView
//   pages/casting_page    — WaitingForMediaView, CastingView
//   pages/debug_page      — DebugPage (used inside connect_page)
//   components/*          — shared components (stubs, populated Phase 3–5)

// ── Bridge + AppState: import for local use, re-export for the Rust backend ──
import { Bridge, AppState, Panel } from "bridge.slint";
export { Bridge, AppState, Panel }

// ── Per-feature globals: re-export so slint_build generates Rust bindings ────
import { SafeArea, AppBridge, PanelBridge, BannerBridge, MediaBackend, Recording,
         Casting, Receivers, History, Macros, Quickbar, BitratePresets,
         Network, Mixer, DebugLog, Camera, Audio } from "state/index.slint";
export { SafeArea, AppBridge, PanelBridge, BannerBridge, MediaBackend, Recording,
         Casting, Receivers, History, Macros, Quickbar, BitratePresets,
         Network, Mixer, DebugLog, Camera, Audio }

// ── Page component imports ────────────────────────────────────────────────────
import { ConnectView }                   from "pages/connect_page.slint";
import { ConnectingView }               from "pages/connecting_page.slint";
import { SettingsPageView, FullSettingsPage } from "pages/settings_page.slint";
import { WaitingForMediaView,
         CastingView }                  from "pages/casting_page.slint";
import { CodecTestPage }                from "pages/codec_test_page.slint";
import { DebugPage, FullDebugPage }     from "pages/debug_page.slint";
import { BackupResetPage }              from "pages/backup_reset_page.slint";
import { AudioPage }                    from "pages/audio_page.slint";
import { BitratePresetsPage }           from "pages/bitrate_presets_page.slint";
import { BitratePresetEditPage }        from "pages/bitrate_preset_edit_page.slint";
import { CameraPage }                   from "pages/camera_page.slint";
import { QuickActionsPage }             from "pages/quick_actions_page.slint";
import { CastHistoryPage }              from "pages/cast_history_page.slint";
import { CastHistoryDetailPage }        from "pages/cast_history_detail_page.slint";
import { RecordingPage }                from "pages/recording_page.slint";
import { PairingPage }                  from "pages/pairing_page.slint";
import { ReceiverRenamePage }           from "pages/receiver_rename_page.slint";
import { MacrosPage }                   from "pages/macros_page.slint";
import { MacroEditPage }                from "pages/macro_edit_page.slint";
import { DebugLogPage }                 from "pages/debug_log_page.slint";
import { DebugVideoPage }               from "pages/debug_video_page.slint";
import { NetworkPage }                  from "pages/network_page.slint";
import { MixerPage }                    from "pages/mixer_page.slint";
import { MediaBackendPage }             from "pages/media_backend_page.slint";
import { TestFunctionalityPage }        from "pages/test_functionality_page.slint";
import { Theme } from "theme.slint";
import { CastControlBar } from "components/control_bar.slint";
import { InfoBanner } from "components/info_banner.slint";
import { PanelHost } from "components/panel_host.slint";

// ── Root window ───────────────────────────────────────────────────────────────
export component MainWindow inherits Window {
    background: Theme.surface-primary;
    forward-focus: back-key-scope;

    // Populate SafeArea once from the platform's native insets.
    // Safe-area insets don't change at runtime on this portrait-only app, so
    // init-time population is sufficient.  Clamping logic lives in SafeArea.
    init => {
        SafeArea.raw-top    = root.safe-area-insets.top;
        SafeArea.raw-bottom = root.safe-area-insets.bottom;
        SafeArea.raw-left   = root.safe-area-insets.left;
        SafeArea.raw-right  = root.safe-area-insets.right;
    }

    back-key-scope := FocusScope {
        width: root.width;
        height: root.height;
        focus-on-click: false;
        focus-on-tab-navigation: false;

        capture-key-pressed(event) => {
            if (event.text == Key.Back) {
                Bridge.back-requested();
                return accept;
            }
            reject
        }

        VerticalLayout {
            // Fill the full window so padding maps 1-to-1 to physical insets.
            width: root.width;
            height: root.height;
            // Keep main content + control bar inside the OS safe area.
            padding-top: SafeArea.top;
            padding-bottom: SafeArea.bottom;
            Rectangle {
                vertical-stretch: 1;
                // Hide (and disable input on) the background page while any panel is open.
                // visible:false blocks both rendering and touch/focus events (Slint docs:
                // common-properties#visible). This prevents background LineEdit elements
                // from stealing focus through the full-screen panel overlay.
                visible: PanelBridge.active == Panel.none;
                // Conditional elements: only the matching view is instantiated.
                // Slint docs: https://releases.slint.dev/1.15.1/docs  (Conditional Elements)
                if Bridge.app-state == AppState.Disconnected:      ConnectView { }
                if Bridge.app-state == AppState.Connecting:        ConnectingView { }
                if Bridge.app-state == AppState.SelectingSettings: SettingsPageView { }
                if Bridge.app-state == AppState.WaitingForMedia:   WaitingForMediaView { }
                if Bridge.app-state == AppState.Casting:           CastingView { }
            }
            CastControlBar { }
        }

        // ── Panel overlay layer ───────────────────────────────────────────────────
        // PanelHost owns the safe-area inset math; each panel inside needs no
        // y / height wiring of its own.
        PanelHost {
            if PanelBridge.active == Panel.settings:            FullSettingsPage        { }
            if PanelBridge.active == Panel.debug:               FullDebugPage           { }
            if PanelBridge.active == Panel.codec-test:          CodecTestPage           { }
            if PanelBridge.active == Panel.backup-reset:        BackupResetPage         { }
            if PanelBridge.active == Panel.audio:               AudioPage               { }
            if PanelBridge.active == Panel.camera:              CameraPage              { }
            if PanelBridge.active == Panel.quick-actions:       QuickActionsPage        { }
            if PanelBridge.active == Panel.cast-history:        CastHistoryPage         { }
            if PanelBridge.active == Panel.cast-history-detail: CastHistoryDetailPage   { }
            if PanelBridge.active == Panel.recording:           RecordingPage           { }
            if PanelBridge.active == Panel.pairing: PairingPage {
                close => { PanelBridge.pop(); }
            }
            if PanelBridge.active == Panel.receiver-rename: ReceiverRenamePage {
                current-name: Bridge.selected-receiver-name;
                save(new-name) => { PanelBridge.pop(); }
                cancel        => { PanelBridge.pop(); }
            }
            if PanelBridge.active == Panel.bitrate-presets:     BitratePresetsPage      { }
            if PanelBridge.active == Panel.bitrate-preset-edit: BitratePresetEditPage   { }
            if PanelBridge.active == Panel.macros:              MacrosPage              { }
            if PanelBridge.active == Panel.macro-edit:          MacroEditPage           { }
            if PanelBridge.active == Panel.debug-log:           DebugLogPage            { }
            if PanelBridge.active == Panel.debug-video:         DebugVideoPage          { }
            if PanelBridge.active == Panel.network:             NetworkPage             { }
            if PanelBridge.active == Panel.mixer:               MixerPage               { }
            if PanelBridge.active == Panel.media-backend:       MediaBackendPage        { }
            if PanelBridge.active == Panel.test-functionality:  TestFunctionalityPage   { }
        }

        // ── Global banner overlay ─────────────────────────────────────────────────
        InfoBanner {
            x: 0;
            y: SafeArea.top;
            width: parent.width;
        }
    }
}
