// state/quickbar.slint — Quick-action bar state.

import { QuickAction, QuickActionKind } from "../bridge.slint";

export global Quickbar {
    in property <[QuickAction]> actions: [];

    callback move-action(from: int, to: int);
    callback set-action-enabled(idx: int, enabled: bool);
    callback save-actions();
    callback invoke(kind: QuickActionKind, custom-id: string);
}
