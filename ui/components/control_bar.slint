// control_bar.slint — Persistent bottom action bar and quick-action buttons.

import { ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Bridge, QuickAction, QuickActionKind, Panel } from "../bridge.slint";

export component QuickActionButton inherits Rectangle {
    in property <QuickAction> action;
    callback invoked(QuickAction);

    height: 48px;
    width: 80px;
    border-radius: Theme.radius-card;
    background: root.action.active
        ? Theme.accent-active
        : (ta.pressed ? Theme.surface-card.brighter(20%) : Theme.surface-card);
    opacity: root.action.enabled ? 1.0 : 0.45;

    accessible-role:    button;
    accessible-label:   root.action.kind == QuickActionKind.run-macro
        ? @tr("macro-quick-action-a11y", "Run macro: {}", root.action.title)
        : root.action.title;
    accessible-enabled: root.action.enabled;
    accessible-checked: root.action.active;
    accessible-action-default => {
        if root.action.enabled { root.invoked(root.action); }
    }

    ta := TouchArea {
        enabled: root.action.enabled;
        clicked => { root.invoked(root.action); }
    }
    Text {
        text: root.action.kind == QuickActionKind.run-macro
            ? "▶ " + root.action.title
            : root.action.title;
        color: Theme.text-primary;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: Theme.font-size-label;
        wrap: word-wrap;
    }
}

export component CastControlBar inherits Rectangle {
    height: Theme.control-bar-height;
    background: Theme.surface-bar;

    ScrollView {
        width: parent.width;
        height: parent.height;
        mouse-drag-pan-enabled: true;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
        viewport-width: actions-row.preferred-width;
        viewport-height: actions-row.preferred-height;

        actions-row := HorizontalLayout {
            padding: Theme.padding-card;
            spacing: Theme.spacing-default;
            alignment: start;

            for action in Bridge.quick-actions: QuickActionButton {
                action: action;
                invoked(act) => {
                    if (act.kind == QuickActionKind.open-settings)   { Bridge.active-panel = Panel.settings;        return; }
                    if (act.kind == QuickActionKind.open-debug)       { Bridge.active-panel = Panel.debug;           return; }
                    if (act.kind == QuickActionKind.open-codec-test)  { Bridge.active-panel = Panel.codec-test;      return; }
                    if (act.kind == QuickActionKind.open-recording)   { Bridge.active-panel = Panel.recording;       return; }
                    if (act.kind == QuickActionKind.open-pairing)     { Bridge.active-panel = Panel.pairing;         return; }
                    if (act.kind == QuickActionKind.open-bitrate)     { Bridge.active-panel = Panel.bitrate-presets; return; }
                    if (act.kind == QuickActionKind.scan-qr)          { Bridge.invoke-action("scan-qr");             return; }
                    // custom and any unhandled kinds — route through Rust via custom-id.
                    Bridge.invoke-action(act.custom-id);
                }
            }
        }
    }
}
