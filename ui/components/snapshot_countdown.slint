import { Theme } from "../theme.slint";
import { Bridge } from "../bridge.slint";
import { DestructiveButton } from "buttons.slint";

export component SnapshotCountdown inherits Rectangle {
    width: 100%;
    height: 100%;
    background: Theme.surface-overlay;

    accessible-role:  text;
    accessible-label: @tr("snapshot-countdown-a11y", "Casting in {} seconds. Press Cancel to abort.", root.remaining);

    property <int> remaining: Bridge.snapshot-secs;

    // Escape cancels the countdown (same as the Cancel button).
    forward-focus: scope;
    scope := FocusScope {
        width: 100%;
        height: 100%;
        key-pressed(event) => {
            if event.text == Key.Escape {
                Bridge.exit-lifecycle();
                return accept;
            }
            return reject;
        }
    }

    Timer {
        interval: 1s;
        running: root.remaining > 0;
        triggered => {
            root.remaining -= 1;
            if (root.remaining <= 0) {
                Bridge.exit-lifecycle();
            }
        }
    }

    Rectangle {
        width: 280px;
        height: 240px;
        border-radius: Theme.radius-card;
        background: Theme.surface-card;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;

        VerticalLayout {
            alignment: center;
            spacing: Theme.spacing-default * 3;
            padding: Theme.padding-screen * 2;

            Text {
                text: @tr("Casting in");
                color: Theme.text-secondary;
                font-size: Theme.font-size-heading;
                horizontal-alignment: center;
            }

            Text {
                text: root.remaining;
                color: Theme.text-primary;
                font-size: Theme.font-size-hero;
                font-weight: 700;
                horizontal-alignment: center;
            }

            DestructiveButton {
                label: @tr("cancel-cast-button" => "Cancel");
                clicked => {
                    Bridge.exit-lifecycle();
                }
            }
        }
    }
}
