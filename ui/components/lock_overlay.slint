import { Theme } from "../theme.slint";
import { Bridge, LifecycleMode } from "../bridge.slint";

export component LockOverlay inherits Rectangle {
    width: 100%;
    height: 100%;
    background: Theme.surface-overlay;

    // Track hold duration
    property <duration> hold-elapsed: 0s;
    property <float> hold-progress: Math.clamp(root.hold-elapsed / 1.5s, 0.0, 1.0);

    Timer {
        interval: 16ms;
        running: hold-area.pressed;
        triggered => {
            root.hold-elapsed += 16ms;
            if (root.hold-elapsed >= 1.5s) {
                Bridge.lifecycle = LifecycleMode.normal;
            }
        }
    }

    hold-area := TouchArea {
        width: 100%;
        height: 100%;
        changed pressed => {
            if (!self.pressed) {
                root.hold-elapsed = 0s;
            }
        }

        Rectangle {
            width: 240px;
            height: 240px;
            border-radius: Theme.radius-card;
            background: Theme.surface-card;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;

            VerticalLayout {
                alignment: center;
                spacing: Theme.spacing-default * 2;
                padding: Theme.padding-screen;

                Text {
                    text: "🔒";
                    font-size: 48px;
                    horizontal-alignment: center;
                }

                Text {
                    text: @tr("UI Locked");
                    color: Theme.text-primary;
                    font-size: Theme.font-size-heading;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                Text {
                    text: @tr("Tap and hold for 1.5s to unlock");
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-body;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                // Progress bar
                Rectangle {
                    width: 80%;
                    height: 8px;
                    border-radius: 4px;
                    background: Theme.surface-primary;
                    horizontal-stretch: 0;

                    Rectangle {
                        x: 0;
                        width: parent.width * root.hold-progress;
                        height: 100%;
                        border-radius: 4px;
                        background: Theme.accent;
                    }
                }
            }
        }
    }
}
