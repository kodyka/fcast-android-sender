import { Theme } from "../theme.slint";
import { Bridge } from "../bridge.slint";

export component LockOverlay inherits Rectangle {
    width: 100%;
    height: 100%;
    background: Theme.surface-overlay;

    accessible-role:  text;
    accessible-label: @tr("lock-overlay-a11y", "UI locked. Tap and hold for 1.5 seconds to unlock.");

    property <float> hold-progress: 0.0;

    // Asymmetric animation: 1.5 s to fill (hold), 200 ms to snap back (release).
    states [
        held     when hold-area.pressed  : { hold-progress: 1.0; in { animate hold-progress { duration: 1.5s;  easing: linear;   } } }
        released when !hold-area.pressed : { hold-progress: 0.0; in { animate hold-progress { duration: 200ms; easing: ease-out; } } }
    ]

    // Fires on every animated frame; only exits when the full 1.5 s completes.
    changed hold-progress => {
        if (root.hold-progress >= 1.0 && hold-area.pressed) {
            Bridge.exit-lifecycle();
        }
    }

    hold-area := TouchArea {
        width: 100%;
        height: 100%;

        Rectangle {
            width: 240px;
            height: 240px;
            border-radius: Theme.radius-card;
            background: Theme.surface-card;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;

            VerticalLayout {
                alignment: center;
                spacing: Theme.spacing-default * 2;
                padding: Theme.padding-screen;

                Text {
                    text: "🔒";
                    font-size: Theme.font-size-display;
                    horizontal-alignment: center;
                }

                Text {
                    text: @tr("UI Locked");
                    color: Theme.text-primary;
                    font-size: Theme.font-size-heading;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                Text {
                    text: @tr("Tap and hold for 1.5s to unlock");
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-body;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                // Progress bar — width binds to animated hold-progress directly.
                Rectangle {
                    width: 80%;
                    height: 8px;
                    border-radius: 4px;
                    background: Theme.surface-primary;
                    horizontal-stretch: 0;

                    Rectangle {
                        x: 0;
                        width: parent.width * root.hold-progress;
                        height: 100%;
                        border-radius: 4px;
                        background: Theme.accent;
                    }
                }
            }
        }
    }
}
