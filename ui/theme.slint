// theme.slint — Design token global (colors, typography, spacing, radii).
// This is a stub created in Phase 1 so all page/component files can import it
// from day one.  Token values are populated in Phase 2.
//
// Slint docs ref (globals): draft/slint/docs/astro/src/content/docs/guide/language/coding/globals.mdx

export global Theme {
    // Surfaces
    out property <color> surface-primary:  #0b1020;
    out property <color> surface-card:     #222633;
    out property <color> surface-bar:      #111827;
    out property <color> surface-overlay:  #1f2937cc;

    // Text
    out property <color> text-primary:     #ffffff;
    out property <color> text-secondary:   #b8becd;
    out property <color> text-disabled:    #6b7280;

    // Accent / interactive
    out property <color> accent:           #4682b4;   // steelblue
    out property <color> accent-muted:     #b0c4de;   // lightsteelblue
    out property <color> accent-active:    #2563eb;
    out property <color> accent-pressed:   #1e40af;

    // Severity
    //
    // Each severity has paired tokens: a dark `*` (or `*-bg`) variant for use
    // as a *background* fill (e.g. DestructiveButton, StatusPill), and a
    // brighter `*-fg` variant for use as *text* color on dark surfaces (e.g.
    // Badge text inside StatusBadgesRow over surface-overlay).  The two roles
    // need different luminance to stay WCAG-AA legible — a single token
    // cannot serve both because a color readable as a 16px label on
    // surface-overlay is too bright to host white label text on top of it.
    out property <color> error:            #c62828;   // bg fill (dark red)
    out property <color> error-fg:         #ef4444;   // fg/text (bright red)
    out property <color> warning:          #ed6c02;   // bg fill (dark amber)
    out property <color> warning-fg:       #ed6c02;   // fg/text (bright orange)
    out property <color> success:          #2e7d32;   // bg fill (dark green)

    // Typography — font sizes are `length`
    out property <length> font-size-heading:  20px;
    out property <length> font-size-body:     16px;
    out property <length> font-size-label:    12px;

    // Spacing
    out property <length> padding-screen:   12px;
    out property <length> padding-card:      8px;
    out property <length> spacing-default:   8px;

    // Shape
    out property <length> radius-card:       8px;
    out property <length> radius-pill:        6px;
    out property <length> row-height:        48px;
    out property <length> control-bar-height: 72px;
}
